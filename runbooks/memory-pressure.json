{
  "id": "memory-pressure",
  "name": "memory-pressure",
  "alert_pattern": "memory.*(OOM|pressure|high|usage|swap)",
  "description": "Investigate and remediate memory pressure conditions.",
  "steps": [
    {
      "order": 1,
      "action": "Check memory usage",
      "command": "free -h",
      "expected_outcome": "Memory and swap usage displayed",
      "timeout_seconds": 30,
      "critical": false
    },
    {
      "order": 2,
      "action": "Identify high-memory processes",
      "command": "ps aux --sort=-%mem | head -20",
      "expected_outcome": "Top memory-consuming processes listed",
      "timeout_seconds": 30,
      "critical": false
    },
    {
      "order": 3,
      "action": "Check for memory leaks",
      "command": "ps aux --sort=-%mem | awk '$4>50 {print $2, $4\"%\", $11}'",
      "expected_outcome": "Potential memory leaks identified",
      "timeout_seconds": 30,
      "critical": false
    },
    {
      "order": 4,
      "action": "Restart or escalate",
      "command": "ps aux --sort=-%mem | awk 'NR>1 && $4>80 {print $2}' | head -3 | while read pid; do kill -15 \"$pid\" 2>/dev/null; done",
      "expected_outcome": "Memory-intensive processes handled",
      "timeout_seconds": 60,
      "critical": true
    }
  ],
  "escalation_message": "Memory pressure critical \u2014 unable to free sufficient resources",
  "created_at": "2026-07-15T05:47:00.439956+00:00"
}